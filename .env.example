NODE_ENV=development
DATABASE_URL="postgresql://entas:entas@localhost:5432/entasburada?schema=public"
REDIS_URL="redis://localhost:6379"
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="dev-master-key"
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY_ID="entas"
S3_SECRET_ACCESS_KEY="entasburada-dev-secret"
S3_BUCKET="entasburada"
AUTH_SECRET="replace-with-a-long-random-secret"
ADMIN_SESSION_SECRET="replace-with-a-long-random-admin-session-secret"
ADMIN_EMAIL="admin@entasburada.local"
ADMIN_PASSWORD="change-me-local-dev-only"
ADMIN_NAME="ENTAS Admin"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
XML_IMPORT_ALLOWED_HOSTS="bayi.euro-mix.com.tr"
OPENAI_API_KEY=""
GEMINI_API_KEY=""
CATALOG_AI_PROVIDER="auto"
CATALOG_DEEP_VERIFY="true"
CATALOG_COMPLETENESS_AUDIT="true"
CATALOG_AI_MAX_ATTEMPTS="3"
CATALOG_AI_MAX_OUTPUT_TOKENS="32000"
CATALOG_PAGE_MAX_ATTEMPTS="3"
CATALOG_ALLOW_TEXT_FALLBACK="false"
CATALOG_MODEL_OCR="true"
OPENAI_CATALOG_MODEL="gpt-5.4-mini"
OPENAI_CATALOG_AUDIT_MODEL="gpt-5.4-mini"
GEMINI_CATALOG_MODEL="gemini-3.1-flash-lite"
GEMINI_CATALOG_FALLBACK_MODEL="gemini-3.5-flash"
CATALOG_PDF_MAX_MB="250"
CATALOG_PDF_MAX_PAGES="400"
CATALOG_PDF_RENDER_DPI="160"
